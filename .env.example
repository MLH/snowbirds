# SnowBirds MCP server config.
#
# Booth laptops authenticate to Snowflake via the `snow` CLI using a
# keypair (no password, no browser). Run ./setup-laptop.sh to wire it up.
#
# The connection name below maps to an entry in ~/.snowflake/config.toml
# that setup-laptop.sh creates for you.
SNOWFLAKE_CONNECTION=databirds

# Override only if your account doesn't match setup.sql's defaults.
SNOWFLAKE_WAREHOUSE=DATA_BIRDS_WH
SNOWFLAKE_DATABASE=DATA_BIRDS_DB
SNOWFLAKE_SCHEMA=AVIARY
